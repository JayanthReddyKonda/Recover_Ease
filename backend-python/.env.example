# ── Database ─────────────────────────────────────────
POSTGRES_USER=rc_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=recovery_companion

# ── JWT ──────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_generate_a_strong_secret_at_least_32_chars

# ── Groq AI ──────────────────────────────────────────
# Get your free key: https://console.groq.com/keys
GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY_HERE
GROQ_MODEL=llama-3.1-70b-versatile

# ── Resend (Email) ───────────────────────────────────
# Get your key: https://resend.com/api-keys
# IMPORTANT: Without a valid key, emails will NOT be sent.
# Free plan sends from onboarding@resend.dev (works for any recipient).
# For custom sender, verify your domain at https://resend.com/domains
RESEND_API_KEY=re_YOUR_RESEND_API_KEY_HERE
RESEND_FROM=Recovery Companion <onboarding@resend.dev>

# ── CORS ─────────────────────────────────────────────
# Set to your frontend URL in production (e.g. https://yourapp.com)
CORS_ORIGIN=*

# ── Frontend Build Args (used by docker compose) ─────
VITE_API_URL=/api
VITE_SOCKET_URL=
