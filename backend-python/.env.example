# ── Database ─────────────────────────────────────────
POSTGRES_USER=rc_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=recovery_companion
# Docker Compose: host = postgres  |  Local dev: host = 127.0.0.1
DATABASE_URL=postgresql+asyncpg://rc_user:CHANGE_ME_strong_password_here@postgres:5432/recovery_companion

# ── Redis ─────────────────────────────────────────────
# Docker Compose: host = redis  |  Local dev: host = 127.0.0.1
REDIS_URL=redis://redis:6379/0

# ── JWT ──────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_generate_a_strong_secret_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ── Groq AI ──────────────────────────────────────────
# Get your free key: https://console.groq.com/keys
GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY_HERE
GROQ_MODEL=llama-3.3-70b-versatile

# ── Gmail SMTP (Email) ───────────────────────────────
# 1. Enable 2-Step Verification: https://myaccount.google.com/security
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Paste the 16-char code (no spaces) into SMTP_PASSWORD
# IMPORTANT: Without valid credentials, emails will be logged only (no failure).
SMTP_USER=you@gmail.com
SMTP_PASSWORD=CHANGE_ME_16_char_app_password
SMTP_FROM_NAME=Recovery Companion

# ── WhatsApp (Meta Cloud API) ─────────────────────────
# Get from https://developers.facebook.com/apps → WhatsApp → API Setup
WHATSAPP_TOKEN=CHANGE_ME_meta_access_token
WHATSAPP_PHONE_NUMBER_ID=CHANGE_ME_phone_number_id
WHATSAPP_VERIFY_TOKEN=recovery_companion_whatsapp

# ── Ngrok (public tunnel for WhatsApp webhook) ────────
# Get from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=CHANGE_ME_paste_your_ngrok_authtoken_here

# ── Server ───────────────────────────────────────────
PORT=8000
CORS_ORIGIN=*
NODE_ENV=production

# ── Frontend Build Args (used by docker compose) ─────
VITE_API_URL=/api
VITE_SOCKET_URL=
