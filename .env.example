# -------------------------------------------------------
# Recovery Companion -- Environment Variables Template
# Copy to backend-python/.env.docker and fill in values:
#   cp .env.example backend-python/.env.docker
# -------------------------------------------------------

# -- PostgreSQL --
POSTGRES_USER=rc_user
POSTGRES_PASSWORD=rc_password
POSTGRES_DB=recovery_companion

# -- Authentication --
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# -- Groq AI (https://console.groq.com/keys) --
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

# -- Resend Email (https://resend.com/api-keys) --
# Leave as placeholder if not using email -- app degrades gracefully
RESEND_API_KEY=re_placeholder_replace_with_real_key
RESEND_FROM=Recovery Companion <onboarding@resend.dev>

# -- CORS --
# Set to your frontend URL, or * to allow all origins
CORS_ORIGIN=*

# -- Environment --
NODE_ENV=production

# -- Ngrok (https://dashboard.ngrok.com/get-started/your-authtoken) --
NGROK_AUTHTOKEN=
