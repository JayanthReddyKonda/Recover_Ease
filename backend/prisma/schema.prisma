generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────

enum Role {
  PATIENT
  DOCTOR
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum Severity {
  CRITICAL
  MONITOR
  NORMAL
}

enum EscalationStatus {
  ACTIVE
  REVIEWED
}

// ─── Models ──────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  role          Role
  condition     String?
  dischargeDate DateTime?
  caregiverEmail String?
  medications   String[] @default([])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  sentRequests     DoctorPatientRequest[] @relation("DoctorRequests")
  receivedRequests DoctorPatientRequest[] @relation("PatientRequests")
  symptomLogs      SymptomLog[]
  escalations      Escalation[]           @relation("PatientEscalations")
  reviewedEscalations Escalation[]        @relation("ReviewerEscalations")
  milestones       Milestone[]

  @@index([email])
  @@index([role])
}

model DoctorPatientRequest {
  id        String        @id @default(cuid())
  doctorId  String
  patientId String
  status    RequestStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  doctor  User @relation("DoctorRequests", fields: [doctorId], references: [id])
  patient User @relation("PatientRequests", fields: [patientId], references: [id])

  @@unique([doctorId, patientId])
  @@index([doctorId])
  @@index([patientId])
  @@index([status])
}

model SymptomLog {
  id              String   @id @default(cuid())
  patientId       String
  logDate         DateTime @db.Date
  pain            Int?
  fatigue         Int?
  swelling        Int?
  sleepHours      Float?
  mood            Int?
  appetite        Int?
  rawInput        String?
  voiceInput      Boolean  @default(false)
  medicationTaken Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patient User @relation(fields: [patientId], references: [id])

  @@unique([patientId, logDate])
  @@index([patientId])
  @@index([logDate])
}

model Escalation {
  id             String           @id @default(cuid())
  patientId      String
  rulesTriggered String[]
  aiVerdict      String?
  aiReason       String?
  aiConfidence   Float?
  severity       Severity         @default(NORMAL)
  isSOS          Boolean          @default(false)
  status         EscalationStatus @default(ACTIVE)
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime         @default(now())

  patient    User  @relation("PatientEscalations", fields: [patientId], references: [id])
  reviewedBy User? @relation("ReviewerEscalations", fields: [reviewedById], references: [id])

  @@index([patientId])
  @@index([severity])
  @@index([status])
}

model Milestone {
  id           String   @id @default(cuid())
  patientId    String
  milestoneKey String
  title        String
  icon         String
  createdAt    DateTime @default(now())

  patient User @relation(fields: [patientId], references: [id])

  @@unique([patientId, milestoneKey])
  @@index([patientId])
}
